#!/bin/bash

# TODO(jwnimmer-tri) Drake's install_prereqs script should offer to perform
# this install step for us, but it doesn't -- so we need this work-around
# in the meantime.

set -euxo pipefail

maybe_sudo=
if [[ "${EUID}" -ne 0 ]]; then
  maybe_sudo=sudo
fi

wget -O bazelisk.deb \
  https://github.com/bazelbuild/bazelisk/releases/download/v1.28.1/bazelisk-amd64.deb
${maybe_sudo} dpkg -i bazelisk.deb
rm -f bazelisk.deb
